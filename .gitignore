node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# Python (if applicable for backend)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env
.pip

# Build outputs (for frontend/backend)
dist/
build/
out/

